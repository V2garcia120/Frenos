@page
@model FrenosCore.Pages.Facturas.IndexModel
@{
    ViewData["Title"] = "Facturas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Facturas</h1>
</div>

<div class="card mb-4">
    <div class="card-header">Filtros</div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label asp-for="Numero" class="form-label">Número de factura</label>
                <input asp-for="Numero" class="form-control" placeholder="FAC-2026-0001" />
            </div>
            <div class="col-md-4">
                <label asp-for="Estado" class="form-label">Estado</label>
                <select asp-for="Estado" class="form-select">
                    <option value="">Todos</option>
                    <option>Pendiente</option>
                    <option>Pagada</option>
                    <option>Anulada</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="TipoOrigen" class="form-label">Tipo origen</label>
                <select asp-for="TipoOrigen" class="form-select">
                    <option value="">Todos</option>
                    <option>OrdenReparacion</option>
                    <option>VentaDirecta</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="Fecha" class="form-label">Fecha</label>
                <input asp-for="Fecha" type="date" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Listado de facturas (@Model.Resultado.TotalItems)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Número</th>
                        <th>Origen</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                        <th>Método pago</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Resultado.Items.Any())
                    {
                        <tr><td colspan="9" class="text-center py-4">No hay facturas para mostrar.</td></tr>
                    }
                    else
                    {
                        @foreach (var factura in Model.Resultado.Items)
                        {
                            <tr>
                                <td>@factura.Id</td>
                                <td>@factura.Numero</td>
                                <td>@factura.TipoOrigen</td>
                                <td>@factura.ClienteNombre</td>
                                <td>@factura.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">@factura.Total.ToString("C")</td>
                                <td>@factura.Estado</td>
                                <td>@(factura.MetodoPago ?? "-")</td>
                                <td class="text-end">
                                    <a asp-page="/Facturas/Detalle" asp-route-id="@factura.Id" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Resultado.TotalPaginas > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Página @Model.Pagina de @Model.Resultado.TotalPaginas</small>
            <nav aria-label="Paginación de facturas">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.HayPaginaAnterior ? string.Empty : "disabled")">
                        <a class="page-link" asp-page="/Facturas/Index"
                           asp-route-Pagina="@(Model.Pagina - 1)"
                           asp-route-Estado="@Model.Estado"
                           asp-route-Numero="@Model.Numero"
                           asp-route-Fecha="@(Model.Fecha?.ToString("yyyy-MM-dd"))"
                           asp-route-TipoOrigen="@Model.TipoOrigen">Anterior</a>
                    </li>
                    @for (var i = 1; i <= Model.Resultado.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == Model.Pagina ? "active" : string.Empty)">
                            <a class="page-link" asp-page="/Facturas/Index"
                               asp-route-Pagina="@i"
                               asp-route-Estado="@Model.Estado"
                               asp-route-Numero="@Model.Numero"
                               asp-route-Fecha="@(Model.Fecha?.ToString("yyyy-MM-dd"))"
                               asp-route-TipoOrigen="@Model.TipoOrigen">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HayPaginaSiguiente ? string.Empty : "disabled")">
                        <a class="page-link" asp-page="/Facturas/Index"
                           asp-route-Pagina="@(Model.Pagina + 1)"
                           asp-route-Estado="@Model.Estado"
                           asp-route-Numero="@Model.Numero"
                           asp-route-Fecha="@(Model.Fecha?.ToString("yyyy-MM-dd"))"
                           asp-route-TipoOrigen="@Model.TipoOrigen">Siguiente</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
