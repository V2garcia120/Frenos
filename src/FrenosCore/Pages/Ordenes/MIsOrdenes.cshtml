@page
@model FrenosCore.Pages.Ordenes.MIsOrdenesModel
@{
    ViewData["Title"] = "Mis órdenes";
}

<div class="module-header mb-4">
    <div>
        <h1 class="h3 mb-1">Mis órdenes</h1>
        <p class="text-secondary mb-0">Consulta y da seguimiento a tus órdenes asignadas.</p>
    </div>
</div>

<div class="card mb-4 filter-card">
    <div class="card-header">Filtros de búsqueda</div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label" asp-for="Estado">Estado</label>
                <select asp-for="Estado" class="form-select">
                    <option value="">Todos</option>
                    <option>Recibido</option>
                    <option>EnDiagnostico</option>
                    <option>Aprobado</option>
                    <option>EnReparacion</option>
                    <option>Lista</option>
                    <option>Entregada</option>
                    <option>Cancelada</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" asp-for="Prioridad">Prioridad</label>
                <select asp-for="Prioridad" class="form-select">
                    <option value="">Todas</option>
                    <option>Normal</option>
                    <option>Alta</option>
                    <option>Urgente</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" asp-for="Fecha">Fecha</label>
                <input asp-for="Fecha" type="date" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Resultados (@Model.Resultado.TotalItems)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Cliente</th>
                        <th>Vehículo</th>
                        <th>Estado</th>
                        <th>Prioridad</th>
                        <th>Ingreso</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Resultado.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">No tienes órdenes para mostrar.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var orden in Model.Resultado.Items)
                        {
                            <tr>
                                <td>@orden.Id</td>
                                <td>@orden.ClienteNombre</td>
                                <td>@orden.VehiculoInfo</td>
                                <td><span class="badge text-bg-light border">@orden.Estado</span></td>
                                <td><span class="badge @(orden.Prioridad == "Urgente" ? "text-bg-danger" : orden.Prioridad == "Alta" ? "text-bg-warning" : "text-bg-secondary")">@orden.Prioridad</span></td>
                                <td>@orden.FechaIngreso.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <a asp-page="/Ordenes/Detalle" asp-route-id="@orden.Id" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Resultado.TotalPaginas > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Página @Model.Pagina de @Model.Resultado.TotalPaginas</small>
            <nav aria-label="Paginación de mis órdenes">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.HayPaginaAnterior ? string.Empty : "disabled")">
                        <a class="page-link" asp-page="/Ordenes/MIsOrdenes"
                           asp-route-Pagina="@(Model.Pagina - 1)"
                           asp-route-Estado="@Model.Estado"
                           asp-route-Prioridad="@Model.Prioridad"
                           asp-route-Fecha="@(Model.Fecha?.ToString("yyyy-MM-dd"))">Anterior</a>
                    </li>
                    @for (var i = 1; i <= Model.Resultado.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == Model.Pagina ? "active" : string.Empty)">
                            <a class="page-link" asp-page="/Ordenes/MIsOrdenes"
                               asp-route-Pagina="@i"
                               asp-route-Estado="@Model.Estado"
                               asp-route-Prioridad="@Model.Prioridad"
                               asp-route-Fecha="@(Model.Fecha?.ToString("yyyy-MM-dd"))">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HayPaginaSiguiente ? string.Empty : "disabled")">
                        <a class="page-link" asp-page="/Ordenes/MIsOrdenes"
                           asp-route-Pagina="@(Model.Pagina + 1)"
                           asp-route-Estado="@Model.Estado"
                           asp-route-Prioridad="@Model.Prioridad"
                           asp-route-Fecha="@(Model.Fecha?.ToString("yyyy-MM-dd"))">Siguiente</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
