@page
@model FrenosCore.Pages.Servicios.IndexModel
@{
    ViewData["Title"] = "Servicios";
    var puedeGestionar = User.IsInRole("Administrador") || User.IsInRole("Admin") || User.IsInRole("Mantenimiento") || User.IsInRole("Mantemineto");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Gestión de servicios</h1>
    @if (puedeGestionar)
    {
        <a asp-page="/Servicios/Create" class="btn btn-primary">Crear servicio</a>
    }
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success">@mensaje</div>
}

@if (TempData["MensajeError"] is string mensajeError)
{
    <div class="alert alert-danger">@mensajeError</div>
}

<div class="card mb-4">
    <div class="card-header">Buscar servicios</div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-10">
                <label class="form-label" asp-for="Termino">Término</label>
                <input asp-for="Termino" class="form-control" placeholder="Nombre, descripción o categoría" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Buscar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Listado de servicios (@Model.Servicios.Count)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Descripción</th>
                        <th class="text-end">Precio</th>
                        <th class="text-end">Duración</th>
                        @if (puedeGestionar)
                        {
                            <th class="text-end">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Servicios.Count == 0)
                    {
                        <tr>
                            <td colspan="@(puedeGestionar ? 6 : 5)" class="text-center py-4">No hay servicios para mostrar.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var servicio in Model.Servicios)
                        {
                            <tr>
                                <td class="fw-semibold">@servicio.Nombre</td>
                                <td>@servicio.Categoria</td>
                                <td>@servicio.Descripcion</td>
                                <td class="text-end">@servicio.Precio.ToString("C")</td>
                                <td class="text-end">@servicio.DuracionMinutos min</td>
                                @if (puedeGestionar)
                                {
                                    <td class="text-end">
                                        <a asp-page="/Servicios/Edit" asp-route-id="@servicio.Id" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                                        <form method="post" asp-page-handler="Eliminar" asp-route-id="@servicio.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Eliminar este servicio?');">Eliminar</button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
