@page
@model FrenosCore.Pages.Dashboard.MantenimientoModel
@{
    ViewData["Title"] = "Dashboard Mantenimiento";
}

<style>
    .mtto-dashboard { background: #f8f9fa; border-radius: 1rem; padding: 1rem; color: #212529; }
    .mtto-card { background: #ffffff; border: 1px solid #dee2e6; border-radius: .9rem; }
    .mtto-title { color: #6c757d; font-size: .9rem; font-weight: 700; text-transform: uppercase; }
    .mtto-value { font-size: 2.1rem; line-height: 1; font-weight: 700; color: #212529; }
    .mtto-warning { color: #fd7e14; font-weight: 600; }
    .mtto-muted { color: #6c757d; }
    .mtto-row { border-top: 1px solid #e9ecef; }
    .mtto-badge { border-radius: 999px; padding: .25rem .75rem; font-weight: 700; font-size: .9rem; display: inline-block; }
    .m-lista { background: #198754; color: #e9f7ef; }
    .m-cotizacion { background: #6610f2; color: #efe7ff; }
    .m-reparando { background: #fd7e14; color: #fff5eb; }
    .m-diagnostico { background: #6610f2; color: #efe7ff; }
    .m-aprobado { background: #198754; color: #e9f7ef; }
    .m-recibido { background: #0d6efd; color: #e7f1ff; }
    .m-default { background: #6c757d; color: #f8f9fa; }
</style>

<div class="mtto-dashboard">
    <div class="row g-3 mb-3">
        <div class="col-lg-4 col-md-6">
            <div class="mtto-card p-3 h-100">
                <div class="mtto-title">Ordenes hoy</div>
                <div class="mtto-value mt-1">@Model.Data.OrdenesHoy</div>
                <div class="mtto-warning mt-2">@Model.Data.OrdenesUrgentesHoy urgentes · @Model.Data.OrdenesListasHoy listas</div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="mtto-card p-3 h-100">
                <div class="mtto-title">Pendientes aprobar</div>
                <div class="mtto-value mt-1">@Model.Data.PendientesAprobar</div>
                <div class="fw-semibold">cotizaciones esperando cliente</div>
            </div>
        </div>
        <div class="col-lg-4 col-md-12">
            <div class="mtto-card p-3 h-100">
                <div class="mtto-title">Listas sin entregar</div>
                <div class="mtto-value mt-1">@Model.Data.ListasSinEntregar</div>
                <div class="mtto-warning">clientes sin notificar</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="mtto-card overflow-hidden">
                <div class="px-3 py-2 border-bottom border-secondary-subtle">
                    <div class="h3 mb-0">Requieren accion</div>
                </div>

                @if (!Model.Data.RequierenAccion.Any())
                {
                    <div class="p-3 mtto-muted">No hay elementos que requieran acción.</div>
                }
                else
                {
                    @foreach (var item in Model.Data.RequierenAccion)
                    {
                        var estado = item.Estado.ToLowerInvariant();
                        var badgeClass = estado.Contains("lista") ? "m-lista" : "m-cotizacion";
                        <div class="p-3 d-flex align-items-start gap-3 mtto-row">
                            <span class="mtto-badge @badgeClass">@item.Estado</span>
                            <div>
                                <div class="fs-4 fw-semibold">@item.Cliente · @item.VehiculoPlaca</div>
                                <div class="mtto-muted fs-5">@item.Descripcion</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="mtto-card overflow-hidden">
                <div class="px-3 py-2 border-bottom border-secondary-subtle">
                    <div class="h3 mb-0">Todas las ordenes de hoy</div>
                </div>

                @if (!Model.Data.OrdenesHoyDetalle.Any())
                {
                    <div class="p-3 mtto-muted">No hay órdenes registradas hoy.</div>
                }
                else
                {
                    @foreach (var item in Model.Data.OrdenesHoyDetalle)
                    {
                        var estado = item.Estado.ToLowerInvariant();
                        var badgeClass = estado.Contains("repar") ? "m-reparando"
                            : estado.Contains("diagn") ? "m-diagnostico"
                            : estado.Contains("aprob") ? "m-aprobado"
                            : estado.Contains("recib") ? "m-recibido"
                            : estado.Contains("lista") ? "m-lista"
                            : "m-default";
                        <div class="p-3 d-flex justify-content-between align-items-start mtto-row">
                            <div>
                                <div class="fs-4 fw-semibold">@item.Cliente</div>
                                <div class="mtto-muted fs-5">@item.VehiculoPlaca · @item.EstadoDetalle</div>
                            </div>
                            <span class="mtto-badge @badgeClass">@item.Estado</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
