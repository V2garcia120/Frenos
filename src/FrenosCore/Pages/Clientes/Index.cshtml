@page
@model FrenosCore.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
    var esAdmin = User.IsInRole("Administrador") || User.IsInRole("Admin");
    var puedeGestionar = esAdmin || User.IsInRole("Mantenimiento") || User.IsInRole("Mantemineto");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Gestión de clientes</h1>
</div>

<div class="card mb-4">
    <div class="card-header">Buscar clientes</div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-8">
                <label class="form-label" asp-for="Termino">Término</label>
                <input asp-for="Termino" class="form-control" placeholder="Nombre, cédula o correo" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Buscar</button>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                @if (puedeGestionar)
                {
                    <a asp-page="/Clientes/Crear" class="btn btn-primary w-100">Crear cliente</a>
                }
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Listado de clientes (@Model.Resultado.TotalItems)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Cédula</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Dirección</th>
                        <th class="text-center">Anónimo</th>
                        @if (puedeGestionar)
                        {
                            <th class="text-center">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Resultado.Items.Any())
                    {
                        <tr>
                            <td colspan="@(puedeGestionar ? 7 : 6)" class="text-center py-4">No hay clientes para mostrar.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var cliente in Model.Resultado.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@cliente.Nombre</td>
                                <td>@(cliente.Cedula ?? "-")</td>
                                <td>@(cliente.Telefono ?? "-")</td>
                                <td>@(cliente.Email ?? "-")</td>
                                <td>@(cliente.Direccion ?? "-")</td>
                                <td class="text-center">@(cliente.EsAnonimo ? "Sí" : "No")</td>
                                @if (puedeGestionar)
                                {
                                    <td class="text-center">
                                        <a asp-page="/Clientes/Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                                        @if (esAdmin)
                                        {
                                            <form method="post" asp-page-handler="Eliminar" asp-route-id="@cliente.Id" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Eliminar este cliente?');">Eliminar</button>
                                            </form>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Resultado.TotalPaginas > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Página @Model.Pagina de @Model.Resultado.TotalPaginas
            </small>
            <nav aria-label="Paginación de clientes">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.HayPaginaAnterior ? string.Empty : "disabled")">
                        <a class="page-link"
                           asp-page="/Clientes/Index"
                           asp-route-Pagina="@(Model.Pagina - 1)"
                           asp-route-Termino="@Model.Termino">Anterior</a>
                    </li>

                    @for (var i = 1; i <= Model.Resultado.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == Model.Pagina ? "active" : string.Empty)">
                            <a class="page-link"
                               asp-page="/Clientes/Index"
                               asp-route-Pagina="@i"
                               asp-route-Termino="@Model.Termino">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.HayPaginaSiguiente ? string.Empty : "disabled")">
                        <a class="page-link"
                           asp-page="/Clientes/Index"
                           asp-route-Pagina="@(Model.Pagina + 1)"
                           asp-route-Termino="@Model.Termino">Siguiente</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
