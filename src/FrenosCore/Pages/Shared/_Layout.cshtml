<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Frenos Core</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FrenosCore.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
@{
    var esAdmin = User.IsInRole("Administrador") || User.IsInRole("Admin");
    var esMantenimiento = User.IsInRole("Mantenimiento") || User.IsInRole("Mantemineto");
    var esTecnico = User.IsInRole("Tecnico") || User.IsInRole("Técnico");
}
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar shadow-sm">
            <div class="container-xl">
                <a class="navbar-brand fw-semibold text-white" asp-area="" asp-page="/Index">Frenos Core</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Mantenimiento
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="" asp-page="/Productos/Index">Productos</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Servicios/Index">Servicios</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-page="/Clientes/Index">Clientes</a></li>
                            </ul>
                        </li>
                        @if (esAdmin || esMantenimiento)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Ordenes/Index">Órdenes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Facturas/Index">Facturas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/CuentasPorCobrar/Index">CxC</a>
                            </li>
                        }
                        @if (esTecnico)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Ordenes/MIsOrdenes">Mis órdenes</a>
                            </li>
                        }
                        @if (esAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Usuarios/Index">Usuarios</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="app-user-badge">@User.Identity.Name</span>
                        }
                        <form method="post" asp-page="/Login/Logout" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-light">Cerrar sesión</button>
                        </form>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-xl page-shell">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container-xl">
            &copy; 2026 - Frenos Core - <a asp-area="" asp-page="/Privacy">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
