@page "{ordenId:int}"
@model FrenosCore.Pages.Diagnosticos.CreateModel
@{
    ViewData["Title"] = "Crear diagnóstico";
}

@if (Model.Orden is not null)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Crear diagnóstico - Orden #@Model.Orden.Id</h1>
        <a asp-page="/Ordenes/Detalle" asp-route-id="@Model.Orden.Id" class="btn btn-outline-secondary">Volver</a>
    </div>

    <div class="card mb-4">
        <div class="card-header">Información de la orden</div>
        <div class="card-body row g-3">
            <div class="col-md-6"><strong>Cliente:</strong> @Model.Orden.ClienteNombre</div>
            <div class="col-md-6"><strong>Vehículo:</strong> @Model.Orden.VehiculoInfo</div>
            <div class="col-md-3"><strong>Estado:</strong> @Model.Orden.Estado</div>
            <div class="col-md-3"><strong>Prioridad:</strong> @Model.Orden.Prioridad</div>
            <div class="col-md-6"><strong>Ingreso:</strong> @Model.Orden.FechaIngreso.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">Datos del diagnóstico</div>
    <div class="card-body">
        <form method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-md-3">
                <label asp-for="Input.KmIngreso" class="form-label"></label>
                <input asp-for="Input.KmIngreso" class="form-control" />
                <span asp-validation-for="Input.KmIngreso" class="text-danger"></span>
            </div>

            <div class="col-md-4 form-check d-flex align-items-end pb-2 ms-2">
                <div>
                    <input asp-for="Input.RequiereAtencionUrgente" class="form-check-input" />
                    <label asp-for="Input.RequiereAtencionUrgente" class="form-check-label"></label>
                </div>
            </div>

            <div class="col-12">
                <label asp-for="Input.DescripcionGeneral" class="form-label"></label>
                <textarea asp-for="Input.DescripcionGeneral" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Input.DescripcionGeneral" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Input.ObservacionesTecnico" class="form-label"></label>
                <textarea asp-for="Input.ObservacionesTecnico" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.ObservacionesTecnico" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">Servicios y productos sugeridos</h2>
                    <button type="button" id="btnAgregarItem" class="btn btn-sm btn-outline-primary">Agregar item</button>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="tablaItemsDiagnostico">
                        <thead>
                            <tr>
                                <th>Sistema</th>
                                <th>Componente</th>
                                <th>Condición</th>
                                <th>Acción</th>
                                <th>Servicio</th>
                                <th>Producto</th>
                                <th>Cant.</th>
                                <th>Urgente</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Input.Items.Count; i++)
                            {
                                <tr>
                                    <td><input asp-for="Input.Items[i].SistemaVehiculo" class="form-control form-control-sm" /></td>
                                    <td><input asp-for="Input.Items[i].Componente" class="form-control form-control-sm" /></td>
                                    <td>
                                        <select asp-for="Input.Items[i].Condicion" class="form-select form-select-sm">
                                            <option>Bueno</option>
                                            <option>Regular</option>
                                            <option>Malo</option>
                                            <option>Critico</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select asp-for="Input.Items[i].AccionRecomendada" class="form-select form-select-sm">
                                            <option>Revisar</option>
                                            <option>Reparar</option>
                                            <option>Reemplazar</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select asp-for="Input.Items[i].ServicioSugeridoId" class="form-select form-select-sm">
                                            <option value="">-</option>
                                            @foreach (var servicio in Model.Servicios)
                                            {
                                                <option value="@servicio.Id">@servicio.Nombre</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <select asp-for="Input.Items[i].ProductoSugeridoId" class="form-select form-select-sm">
                                            <option value="">-</option>
                                            @foreach (var producto in Model.Productos)
                                            {
                                                <option value="@producto.Id">@producto.Nombre</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input asp-for="Input.Items[i].CantidadProductoSugerida" class="form-control form-control-sm" min="0" /></td>
                                    <td class="text-center"><input asp-for="Input.Items[i].EsUrgente" class="form-check-input mt-2" /></td>
                                    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger btn-quitar-item">Quitar</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Crear diagnóstico</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (() => {
            const tabla = document.getElementById('tablaItemsDiagnostico');
            const tbody = tabla.querySelector('tbody');
            const btnAgregar = document.getElementById('btnAgregarItem');

            function servicioOptions() {
                return `
                    <option value="">-</option>
                    @foreach (var servicio in Model.Servicios)
                    {
                        <text><option value="@servicio.Id">@servicio.Nombre</option></text>
                    }
                `;
            }

            function productoOptions() {
                return `
                    <option value="">-</option>
                    @foreach (var producto in Model.Productos)
                    {
                        <text><option value="@producto.Id">@producto.Nombre</option></text>
                    }
                `;
            }

            function reindexar() {
                const filas = tbody.querySelectorAll('tr');
                filas.forEach((fila, index) => {
                    const controles = fila.querySelectorAll('input, select, textarea');
                    controles.forEach(ctrl => {
                        if (ctrl.name) {
                            ctrl.name = ctrl.name.replace(/Input\.Items\[\d+\]/, `Input.Items[${index}]`);
                        }
                        if (ctrl.id) {
                            ctrl.id = ctrl.id.replace(/Input_Items_\d+__/, `Input_Items_${index}__`);
                        }
                    });
                });
            }

            btnAgregar.addEventListener('click', () => {
                const index = tbody.querySelectorAll('tr').length;
                const fila = document.createElement('tr');
                fila.innerHTML = `
                    <td><input name="Input.Items[${index}].SistemaVehiculo" class="form-control form-control-sm" /></td>
                    <td><input name="Input.Items[${index}].Componente" class="form-control form-control-sm" /></td>
                    <td>
                        <select name="Input.Items[${index}].Condicion" class="form-select form-select-sm">
                            <option>Bueno</option><option>Regular</option><option>Malo</option><option>Critico</option>
                        </select>
                    </td>
                    <td>
                        <select name="Input.Items[${index}].AccionRecomendada" class="form-select form-select-sm">
                            <option>Revisar</option><option>Reparar</option><option>Reemplazar</option>
                        </select>
                    </td>
                    <td><select name="Input.Items[${index}].ServicioSugeridoId" class="form-select form-select-sm">${servicioOptions()}</select></td>
                    <td><select name="Input.Items[${index}].ProductoSugeridoId" class="form-select form-select-sm">${productoOptions()}</select></td>
                    <td><input name="Input.Items[${index}].CantidadProductoSugerida" type="number" min="0" class="form-control form-control-sm" value="0" /></td>
                    <td class="text-center"><input name="Input.Items[${index}].EsUrgente" type="checkbox" class="form-check-input mt-2" /></td>
                    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger btn-quitar-item">Quitar</button></td>
                `;
                tbody.appendChild(fila);
            });

            tbody.addEventListener('click', (event) => {
                const boton = event.target.closest('.btn-quitar-item');
                if (!boton) return;

                const filas = tbody.querySelectorAll('tr');
                if (filas.length <= 1) return;

                boton.closest('tr')?.remove();
                reindexar();
            });
        })();
    </script>
}
