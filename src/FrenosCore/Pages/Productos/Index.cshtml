@page

@model FrenosCore.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Gestión de productos</h1>
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success">@mensaje</div>
}

@if (TempData["MensajeError"] is string mensajeError)
{
    <div class="alert alert-danger">@mensajeError</div>
}

<div class="card mb-4">
    <div class="card-header">Buscar productos</div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-8">
                <label class="form-label" asp-for="Termino">Término</label>
                <input asp-for="Termino" class="form-control" placeholder="Nombre o descripción" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Buscar</button>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <a asp-page="/Productos/Create" class="btn btn-primary w-100">Crear producto</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Listado de productos (@Model.Productos.Count)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th class="text-end">Precio</th>
                        <th class="text-end">Costo</th>
                        <th class="text-end">Stock</th>
                        <th class="text-end">Stock mínimo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Productos.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4">No hay productos para mostrar.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var producto in Model.Productos)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@producto.Nombre</div>
                                    <div class="small text-muted">@producto.Descripcion</div>
                                </td>
                                <td>@producto.Categoria</td>
                                <td class="text-end">@producto.Precio.ToString("C")</td>
                                <td class="text-end">@producto.Costo.ToString("C")</td>
                                <td class="text-end">@producto.Stock</td>
                                <td class="text-end">@producto.StockMinimo</td>
                                <td class="text-end">
                                    <a asp-page="/Productos/Edit" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                                    <form method="post" asp-page-handler="Eliminar" asp-route-id="@producto.Id" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Eliminar este producto?');">Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

