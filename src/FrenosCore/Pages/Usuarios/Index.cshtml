@page
@model FrenosCore.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Gestión de usuarios</h1>
    <a asp-page="/Usuarios/Create" class="btn btn-primary">Crear usuario</a>
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success">@mensaje</div>
}

@if (TempData["MensajeError"] is string mensajeError)
{
    <div class="alert alert-danger">@mensajeError</div>
}

<div class="card mb-4">
    <div class="card-header">Buscar usuarios</div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-10">
                <label class="form-label" asp-for="Termino">Término</label>
                <input asp-for="Termino" class="form-control" placeholder="Nombre, correo o rol" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Buscar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Listado de usuarios (@Model.Usuarios.Count)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Fecha creación</th>
                        <th>Último login</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Usuarios.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4">No hay usuarios para mostrar.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var usuario in Model.Usuarios)
                        {
                            <tr>
                                <td class="fw-semibold">@usuario.Nombre</td>
                                <td>@usuario.Email</td>
                                <td>@usuario.Rol</td>
                                <td>@usuario.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(usuario.UltimoLogin?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="Desactivar" asp-route-id="@usuario.Id" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Desactivar este usuario?');">Desactivar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
