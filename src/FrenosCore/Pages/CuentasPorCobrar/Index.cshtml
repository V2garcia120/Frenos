@page
@model FrenosCore.Pages.CuentasPorCobrar.IndexModel
@{
    ViewData["Title"] = "Cuentas por cobrar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Cuentas por cobrar</h1>
</div>

<div class="card mb-4">
    <div class="card-header">Filtro por estado</div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label asp-for="Estado" class="form-label">Estado</label>
                <select asp-for="Estado" class="form-select">
                    <option value="">Todos</option>
                    <option>Pendiente</option>
                    <option>Pagada</option>
                    <option>Vencida</option>
                    <option>Anulada</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Listado de cuentas (@Model.Resultado.TotalItems)</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Factura</th>
                        <th>Cliente</th>
                        <th class="text-end">Monto</th>
                        <th class="text-end">Saldo</th>
                        <th>Vencimiento</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Resultado.Items.Any())
                    {
                        <tr><td colspan="8" class="text-center py-4">No hay cuentas por cobrar para mostrar.</td></tr>
                    }
                    else
                    {
                        @foreach (var cxc in Model.Resultado.Items)
                        {
                            <tr>
                                <td>@cxc.Id</td>
                                <td>@cxc.NumeroFactura</td>
                                <td>@cxc.ClienteNombre</td>
                                <td class="text-end">@cxc.Monto.ToString("C")</td>
                                <td class="text-end">@cxc.Saldo.ToString("C")</td>
                                <td>@cxc.Vencimiento.ToString("dd/MM/yyyy")</td>
                                <td>@cxc.Estado</td>
                                <td class="text-end">
                                    <a asp-page="/CuentasPorCobrar/Detalle" asp-route-id="@cxc.Id" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Resultado.TotalPaginas > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Página @Model.Pagina de @Model.Resultado.TotalPaginas</small>
            <nav aria-label="Paginación de cuentas por cobrar">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.HayPaginaAnterior ? string.Empty : "disabled")">
                        <a class="page-link" asp-page="/CuentasPorCobrar/Index" asp-route-Pagina="@(Model.Pagina - 1)" asp-route-Estado="@Model.Estado">Anterior</a>
                    </li>
                    @for (var i = 1; i <= Model.Resultado.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == Model.Pagina ? "active" : string.Empty)">
                            <a class="page-link" asp-page="/CuentasPorCobrar/Index" asp-route-Pagina="@i" asp-route-Estado="@Model.Estado">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HayPaginaSiguiente ? string.Empty : "disabled")">
                        <a class="page-link" asp-page="/CuentasPorCobrar/Index" asp-route-Pagina="@(Model.Pagina + 1)" asp-route-Estado="@Model.Estado">Siguiente</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
