@page "/pago"
@page "/pago/{MontoExterno:decimal}/{FacturaId:int}"
@using FrenosWeb.Services
@using FrenosWeb.Models
@using Microsoft.AspNetCore.Authorization
@inject CarritoStateService carritoService
@inject NavigationManager navManager
@inject PagoService pagoService
@inject FacturaService facturaService
@attribute [Authorize]

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">💳 Pago con Tarjeta</h4>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <small class="text-muted">Total a pagar (con ITBIS)</small>
                        <h2 class="text-success font-weight-bold">
                            RD$ @montoAFacturar.ToString("N2")
                        </h2>
                    </div>

                    <form @onsubmit="ProcesarPago">

                        <div class="mb-3">
                            <label class="form-label">Nombre en la tarjeta</label>
                            <input type="text" class="form-control" placeholder="Ej. JUAN PEREZ"
                                   @bind="nombreTarjeta" @bind:event="oninput" @onkeyup="ValidarNombre" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Número de Tarjeta</label>
                            <input type="text" class="form-control"
                                   placeholder="0000 0000 0000 0000"
                                   maxlength="16"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Expiración (MM/AA)</label>
                                <input type="text" class="form-control" placeholder="MM/AA"
                                       maxlength="5"
                                       @bind="expiracion" @bind:event="oninput"
                                       @onkeyup="ValidarExpiracion" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">CVV</label>
                                <input type="password" class="form-control" placeholder="***"
                                       maxlength="3"
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(mensajeError))
                        {
                            <div class="alert alert-danger mt-3 mb-0 py-2 shadow-sm text-center">
                                <small>@mensajeError</small>
                            </div>
                        }

                        @if (estaProcesando)
                        {
                            <div class="text-center my-3">
                                <div class="spinner-border text-primary" role="status"></div>
                                <p class="mt-2 text-primary">Validando transacción...</p>
                            </div>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-success btn-lg w-100 shadow mt-3">
                                🔒 Confirmar Pago
                            </button>
                        }

                        <button type="button"
                                class="btn btn-outline-secondary w-100 mt-2 rounded-pill"
                                @onclick='() => navManager.NavigateTo("/carrito")'>
                            ← Volver al carrito
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool estaProcesando = false;
    private string expiracion = "";
    private string nombreTarjeta = "";
    private string? mensajeError;

    [Parameter] public decimal MontoExterno { get; set; }
    [Parameter] public int FacturaId { get; set; }
    [SupplyParameterFromQuery(Name = "vehiculoId")] public int? VehiculoId { get; set; }
    [SupplyParameterFromQuery(Name = "clienteId")] public int? ClienteId { get; set; }
    private decimal montoAFacturar;

    protected override void OnInitialized()
    {
        montoAFacturar = MontoExterno > 0 ? MontoExterno : carritoService.TotalFinal;
    }

    private async Task ProcesarPago()
    {
        estaProcesando = true;
        mensajeError = null;

        try
        {
            if (string.IsNullOrWhiteSpace(nombreTarjeta) ||
                string.IsNullOrWhiteSpace(expiracion))
            {
                mensajeError = "Por favor completa los datos de la tarjeta.";
                return;
            }

            var request = carritoService.PrepararCobro(
                metodoPago: "Tarjeta",
                vehiculoId: VehiculoId.HasValue && VehiculoId.Value > 0 ? VehiculoId : null,
                clienteId: ClienteId ?? 0);

            var resultado = await pagoService.ProcesarCobroAsync(request, "Tarjeta");

            if (resultado.Success)
            {
                await carritoService.Limpiar();
                var msg = resultado.Data?.Estado == "Pendiente"
                    ? "Tu orden fue creada. El taller te contactará para confirmar."
                    : "¡Pago procesado exitosamente!";

                navManager.NavigateTo(
                    $"/mis-ordenes?msg={Uri.EscapeDataString(msg)}");
            }
            else
            {
                mensajeError = resultado.Error?.Mensaje ?? "Error al procesar el pago.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            estaProcesando = false;
        }
    }

    private void ValidarExpiracion(KeyboardEventArgs e)
    {
        var soloNumeros = new string(expiracion.Where(char.IsDigit).ToArray());

        if (soloNumeros.Length > 4)
            soloNumeros = soloNumeros.Substring(0, 4);

        if (soloNumeros.Length >= 2)
        {
            int mes = int.Parse(soloNumeros.Substring(0, 2));
            if (mes > 12) soloNumeros = "12" + (soloNumeros.Length > 2 ? soloNumeros.Substring(2) : "");
            if (mes == 0) soloNumeros = "01" + (soloNumeros.Length > 2 ? soloNumeros.Substring(2) : "");
        }

        if (soloNumeros.Length == 4)
        {
            int mesIngresado = int.Parse(soloNumeros.Substring(0, 2)); 
            int anioIngresado = int.Parse(soloNumeros.Substring(2, 2));
            int anioActual = DateTime.Now.Year % 100;
            int mesActual = DateTime.Now.Month;

            if (anioIngresado < anioActual)
            {
                soloNumeros = soloNumeros.Substring(0, 2) + anioActual.ToString();
                mensajeError = "⚠️ La tarjeta no puede estar expirada.";
            }
            else if (anioIngresado == anioActual && mesIngresado < mesActual)
            {
                soloNumeros = mesActual.ToString("D2") + anioIngresado.ToString();
                mensajeError = "⚠️ El mes ya ha pasado.";
            }
            else if (anioIngresado > anioActual + 20)
            {
                soloNumeros = soloNumeros.Substring(0, 2) + (anioActual + 10).ToString();
            }
        }

        expiracion = soloNumeros.Length > 2 ? soloNumeros.Insert(2, "/") : soloNumeros;
    }

    private void ValidarNombre()
    {
        var filtrado = new string(nombreTarjeta
            .Where(c => char.IsLetter(c) || char.IsWhiteSpace(c)).ToArray());
        nombreTarjeta = filtrado.ToUpper();
    }
}