@page "/catalogo"
@using FrenosWeb.Models
@using FrenosWeb.Services
@using FrenosWeb.Components
@inject ProductoService productoService
@inject ServicioService servicioService
@inject AuthService authService
@inject NavigationManager navManager
@inject CarritoStateService carritoService

<h2 class="fw-bold mb-4" style="color: #1a1a1a;">Catálogo de Productos</h2>
@if (productos == null)
{
    <p>Cargando productos...</p>
}
else
{
    <div class="row">
        @foreach (var item in productos)
        {
            <div class="col-md-4">
                <ProductoCard Id="@item.Id"
                              Nombre="@item.Nombre"
                              Precio="@item.Precio"
                              OnAgregar="@(() => HandleAgregarAlCarrito(item.Precio, item.Nombre, item.Id))" />
            </div>
        }
    </div>
}

<h2 class="fw-bold mt-5 mb-4" style="color: #1a1a1a;">Nuestros Servicios</h2>
@if (servicios == null)
{
    <p>Cargando servicios...</p>
}
else
{
    <div class="row">
        @foreach (var s in servicios)
        {
            <div class="col-md-4">
                <ProductoCard Id="@s.Id"
                              Nombre="@s.Nombre"
                              Precio="@s.Precio"
                              OnAgregar="@(() => HandleAgregarAlCarrito(s.Precio, s.Nombre, s.Id))" />
            </div>
        }
    </div>
}

@code {
    private List<Producto> productos = new();
    private List<Servicio> servicios = new();

    protected override async Task OnInitializedAsync()
    {
        productos = await productoService.GetProductosAsync();
        servicios = await servicioService.GetServiciosAsync();
    }

    private void HandleAgregarAlCarrito(decimal precio, string nombre, int id)
    {
        if (!authService.IsLoggedIn)
        {
            navManager.NavigateTo("login");
        }
        else
        {
            var item = new Producto { Id = id, Nombre = nombre, Precio = precio };
            carritoService.Agregar(item);
        }
    }
}