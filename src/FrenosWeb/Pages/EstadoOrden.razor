@page "/estado/{OrdenId}"
@using FrenosWeb.Models
@inject NavigationManager navManager

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">🔍 Seguimiento de Orden</h4>
                    <small>ID: @OrdenId</small>
                </div>
                <div class="card-body p-5">
                    
                    @if (orden == null)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2">Buscando información en el taller...</p>
                        </div>
                    }
                    else
                    {
                        @* Linea de tiempo del estado *@
                        <div class="step-tracker mb-5">
                            <div class="d-flex justify-content-between position-relative">
                                <div class="step-line"></div>
                                @foreach (var etapa in etapas)
                                {
                                    <div class="text-center position-relative" style="z-index: 2; width: 20%;">
                                        <div class="step-dot @(GetEtapaClass(etapa))">
                                            @if(EsEtapaCompletada(etapa)) { <span>✓</span> }
                                        </div>
                                        <div class="small mt-2 fw-bold">@etapa</div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row bg-light p-3 rounded-3 border">
                            <div class="col-6">
                                <p class="mb-1 text-muted">Vehículo:</p>
                                <p class="fw-bold text-dark">@orden.Vehiculo</p>
                            </div>
                            <div class="col-6 text-end">
                                <p class="mb-1 text-muted">Estado Actual:</p>
                                <span class="badge bg-primary fs-6">@orden.EstadoServicio</span>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <p class="text-muted">¿Tienes dudas? Llámanos con tu ID de orden al <strong>809-555-0123</strong></p>
                            <button class="btn btn-link" @onclick='() => navManager.NavigateTo("/catalogo")'>Regresar al inicio</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .step-line { position: absolute; top: 15px; left: 10%; right: 10%; height: 4px; bg-color: #e9ecef; z-index: 1; background: #dee2e6; }
    .step-dot { width: 35px; height: 35px; border-radius: 50%; background: #dee2e6; margin: 0 auto; line-height: 35px; color: white; transition: 0.3s; }
    .dot-active { background: #0d6efd; box-shadow: 0 0 10px rgba(13, 110, 253, 0.5); }
    .dot-completed { background: #198754; }
</style>

@code {
    [Parameter] public string OrdenId { get; set; } = "";
    private OrdenWebModel? orden;
    
    private readonly string[] etapas = { "Pendiente", "Diagnóstico", "Reparación", "Listo", "Entregado" };

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            // 1. Intentaríamos conectar con la API real
            // var respuesta = await ordenService.GetEstadoPorIdAsync(OrdenId);
            // orden = respuesta;

            // Forzamos el salto al catch para usar los datos simulados por ahora
            throw new Exception("Buscando en servidor local...");
        }
        catch (Exception ex)
        {
            // 2. Failover: Si la API no responde, cargamos el "Falso"
            Console.WriteLine($"[Cyber-Logs] Consultando estado local para {OrdenId}: {ex.Message}");
            
            await Task.Delay(1200); 

            orden = new OrdenWebModel 
            { 
                NumeroOrden = OrdenId, 
                Vehiculo = "Toyota Corolla 2022 (Simulado)", 
                EstadoServicio = "Reparación", // Cambia esto a "Listo" para ver como avanza la barra
                Placa = "A123456"
            };
        }
    }

    private string GetEtapaClass(string etapa) 
    {
        if (orden == null) return "";
        
        int indexActual = Array.IndexOf(etapas, orden.EstadoServicio);
        int indexEtapa = Array.IndexOf(etapas, etapa);

        if (indexEtapa < indexActual) return "dot-completed";
        if (indexEtapa == indexActual) return "dot-active";
        return "";
    }

    private bool EsEtapaCompletada(string etapa) 
    {
        if (orden == null) return false;
        return Array.IndexOf(etapas, etapa) < Array.IndexOf(etapas, orden.EstadoServicio);
    }
}