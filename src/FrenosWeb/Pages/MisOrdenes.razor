@page "/mis-ordenes"
@using FrenosWeb.Models
@using FrenosWeb.Services
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager navManager
@inject OrdenWebService ordenService
@inject AuthService authService
@attribute [Authorize]

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <span class="bi bi-clock-history"></span> Mi Historial de Órdenes
        </h2>
        <button class="btn btn-outline-primary btn-sm" @onclick='() => navManager.NavigateTo("/catalogo")'>
            + Nuevo Servicio
        </button>
    </div>

    @if (historial == null)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Cargando tus órdenes...</p>
        </div>
    }
    else if (!historial.Any())
    {
        <div class="alert alert-info text-center shadow-sm">
            Aún no tienes órdenes registradas. <a href="/catalogo" class="alert-link">¡Empieza aquí!</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>Orden #</th>
                            <th>Fecha</th>
                            <th>Servicio/Producto</th>
                            <th>Vehículo/Placa</th>
                            <th>Estado</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var orden in historial)
                        {
                            <tr>
                                <td class="fw-bold">@orden.NumeroOrden</td>
                                <td class="text-muted">@orden.Fecha.ToString("dd/MM/yyyy")</td>
                                <td class="text-start">
                                    <span class="text-dark fw-semibold">@orden.TipoServicio</span>
                                </td>
                                <td>
                                    @if (orden.EsServicio)
                                    {
                                        <div class="fw-bold">@orden.Vehiculo</div>
                                        <small class="text-muted">[@orden.Placa]</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted font-italic" style="font-style: italic;">Venta Directa (Sin Vehículo)</span>
                                    }
                                </td>
                                <td>
                                    @if (orden.EsServicio)
                                    {
                                        <span class="badge rounded-pill @GetEstadoClass(orden.EstadoServicio)">
                                            @orden.EstadoServicio
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill @GetEstadoClass(orden.EstadoServicio)">
                                            📦 @orden.EstadoServicio
                                        </span>
                                    }
                                </td>
                                <td class="text-end fw-bold text-success">
                                    RD$ @orden.Total.ToString("N2")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<OrdenWebModel>? historial;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await authService.InicializarSesionDesdeStorage();
            historial = await ordenService.GetHistorialAsync();
            StateHasChanged();
        }
    }

    private string GetEstadoClass(string estado) => estado switch
    {
        "Recibido" => "bg-warning text-dark",
        "Pendiente" => "bg-warning text-dark",
        "Pagada" => "bg-success",
        "En diagnóstico" => "bg-info text-dark",
        "En reparación" => "bg-primary",
        "Listo" => "bg-success",
        "Entregado" => "bg-dark",
        _ => "bg-secondary"
    };

    private void DescargarComprobante(string nro) =>
        navManager.NavigateTo($"/facturas?buscar={Uri.EscapeDataString(nro)}");
}