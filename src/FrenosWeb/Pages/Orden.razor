@page "/orden"
@using FrenosWeb.Services
@inject CarritoStateService carritoService
@inject NavigationManager navManager

<div class="container mt-5">
    <div class="card border-primary shadow-lg">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📋 Resumen de Confirmación</h3>
        </div>
        
        <div class="card-body">
            @if (!carritoService.Items.Any())
            {
                <div class="alert alert-warning">
                    No hay productos en la orden. <a href="catalogo">Vuelve al catálogo aquí.</a>
                </div>
            }
            else
            {
                <h5>Detalle de la Orden:</h5>
                <ul class="list-group list-group-flush mb-4">
                    @foreach (var item in carritoService.Items)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@item.Producto.Nombre</strong>
                                <span class="text-muted ms-2">(x @item.Cantidad)</span>
                            </div>
                            <span>RD$ @item.TotalLinea.ToString("N2")</span>
                        </li>
                    }
                </ul>

                <div class="bg-light p-3 border rounded">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Subtotal:</span>
                        <span>RD$ @carritoService.Subtotal.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">ITBIS (18%):</span>
                        <span>RD$ @carritoService.Impuesto.ToString("N2")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Total:</h4>
                        <h4 class="mb-0 text-success font-weight-bold">RD$ @carritoService.TotalFinal.ToString("N2")</h4>
                    </div>
                </div>
            }
        </div>

        <div class="card-footer bg-white d-flex justify-content-between">
            <button class="btn btn-outline-secondary" @onclick='() => navManager.NavigateTo("/carrito")'>
                ⬅ Editar Carrito
            </button>
            
            @if (carritoService.Items.Any())
            {
                <button class="btn btn-primary btn-lg" @onclick="ConfirmarOrden">
                    Confirmar y Proceder al Pago 💳
                </button>
            }
        </div>
    </div>
</div>

@code {
    private void ConfirmarOrden()
    {
        // En la Fase 5, aqui llamariamos a Diana (Integracion) para guardar la orden
        // en la base de datos de "Ordenes Pendientes".
        // Por ahora, solo avanzamos en el flujo simulado.
        
        navManager.NavigateTo("/pago");
    }
}