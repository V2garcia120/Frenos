@using FrenosWeb.Services

<div class="card h-100 shadow border-0 rounded-4 item-card position-relative"
     @onclick="HandleVerDetalle"
     style="cursor: @(!EsServicio && Stock == 0 ? "not-allowed" : "pointer");
    opacity: @(!EsServicio && Stock == 0 ? "0.6" : "1");
    transition: all 0.3s ease;
    border-bottom: 4px solid var(--azul-frenos) !important;">
    <div class="card-body text-center p-4">
        
        <div class="mb-3 mt-2">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm"
                 style="width: 85px; height: 85px; background-color: @(EsServicio ? "#fff3e6" : "#e6f0ff"); border: 2px solid @(EsServicio ? "var(--naranja-frenos)" : "var(--azul-frenos)");">
                <i class="bi @(EsServicio ? "bi-wrench-adjustable text-naranja" : "bi-gear-wide-connected text-azul")"
                   style="font-size: 2.8rem;"></i>
            </div>
        </div>
        
        <h5 class="fw-bold mb-2" style="color: #222;">@Nombre</h5>
        
        <p class="fw-bold fs-3 mb-3" style="color: var(--azul-frenos); letter-spacing: -1px;">
            RD$ @Precio.ToString("N0")
        </p>
        
        <button class="btn btn-frenos-azul w-100 rounded-pill py-2 shadow fw-bold">
            <i class="bi bi-eye-fill me-2"></i>Ver Detalles
        </button>

        @if (!EsServicio && Stock == 0)
        {
            <span class="badge bg-danger rounded-pill w-100 py-2">Sin Stock</span>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string Nombre { get; set; } = "";
    [Parameter] public decimal Precio { get; set; }
    [Parameter] public bool EsServicio { get; set; }
    [Parameter] public int Stock { get; set; }
    [Parameter] public EventCallback<int> OnVerDetalle { get; set; }

    private async Task HandleVerDetalle() => await OnVerDetalle.InvokeAsync(Id);
}