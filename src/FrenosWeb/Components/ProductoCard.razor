@using FrenosWeb.Services
@inject CarritoStateService carritoService

<div style="border:1px solid #ccc; padding:15px; margin:10px; border-radius: 8px; box-shadow: 2px 2px 5px #eee;">
    <h4>@Nombre</h4>
    <p>Precio: <strong>RD$ @Precio</strong></p>
    
    <button @onclick="AgregarAlCarrito"
            style="background-color: #28a745; color: white; border: none; padding: 8px 15px; cursor: pointer; border-radius: 4px;">
        🛒 Agregar al Carrito
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; } // Añadimos el ID para saber que producto es
    [Parameter] public string Nombre { get; set; } = string.Empty;
    [Parameter] public decimal Precio { get; set; }

    private void AgregarAlCarrito()
    {
        // Creamos el objeto con la data del parametro
        var productoAAgregar = new FrenosWeb.Models.Producto
        {
            Id = this.Id,
            Nombre = this.Nombre,
            Precio = this.Precio
        };

        // Lo mandamos al servicio global
        carritoService.Agregar(productoAAgregar);

        // Mensaje de control para mi en la consola del navegador
        Console.WriteLine($"[Web-Pamela] Producto agregado: {Nombre}");
    }
}