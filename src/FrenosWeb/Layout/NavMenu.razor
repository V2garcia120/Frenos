@using FrenosWeb.Services
@inject CarritoStateService carritoService
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">FrenosWeb</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        @* Inicio *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @* Catalogo *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="catalogo">
                <span class="bi bi-shop" aria-hidden="true"></span> Catálogo
            </NavLink>
        </div>

        @* Carrito con contador en tiempo real *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="carrito">
                <span class="bi bi-cart-fill" aria-hidden="true"></span> Carrito
                @if (carritoService.Items.Count > 0)
                {
                    <span class="badge rounded-pill bg-warning text-dark ms-2">
                        @carritoService.Items.Count
                    </span>
                }
            </NavLink>
        </div>

        @* Mis Ordenes - historial del cliente *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="misordenes">
                <span class="bi bi-file-earmark-text-fill" aria-hidden="true"></span> Mis Órdenes
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    // Suscribirse al evento para que el contador se actualice solo
    protected override void OnInitialized()
    {
        carritoService.OnChange += StateHasChanged;
    }

    // Desvincular eventos para evitar fugas de memoria
    public void Dispose()
    {
        carritoService.OnChange -= StateHasChanged;
    }
}