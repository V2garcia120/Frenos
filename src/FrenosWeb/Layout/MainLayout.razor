@inherits LayoutComponentBase
@inject AuthService authService
@inject NavigationManager navManager
@inject CarritoStateService carritoService
@implements IDisposable

<div class="page">
    <main>
        <div class="top-row px-4 d-flex align-items-center shadow-sm" style="background-color: #1a1a1a; border-bottom: 1px solid #333;">

            <div class="d-flex align-items-center">
                <span class="text-white fw-bold me-4" style="font-size: 1.2rem; letter-spacing: 1px;">TALLER DE FRENOS</span>

                <NavLink href="/" class="nav-link text-white-50 px-3 hover-link" Match="NavLinkMatch.All">Inicio</NavLink>
    
                <NavLink href="catalogo" class="nav-link text-white-50 px-3 hover-link">Catálogo</NavLink>

                <AuthorizeView>
                    <Authorized>
                        <div class="px-3">
                            <NavLink href="carrito" class="nav-link p-0 hover-link d-flex align-items-center" style="color: rgba(255,255,255,0.7);">
                                <i class="bi bi-cart3 me-2" style="font-size: 1.4rem;"></i>
                                <span class="me-1">Carrito</span>
                                @if (carritoService.Items.Count > 0)
                                {
                                    <span class="badge rounded-pill bg-danger"
                                          style="font-size: 0.65rem; margin-top: -10px; margin-left: -2px;">
                                        @carritoService.Items.Count
                                    </span>
                                }
                            </NavLink>
                        </div>

                        <NavLink href="mis-ordenes" class="nav-link text-white-50 px-3 hover-link">Mis Órdenes</NavLink>

                        <NavLink href="mis-vehiculos" class="nav-link text-white-50 px-3 hover-link">Mis Vehículos</NavLink>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="ms-auto d-flex align-items-center">
                <AuthorizeView>
                    <Authorized>
                        <span class="text-white-50 me-3 small">Hola, @context.User.Identity?.Name</span>
                        <button class="btn btn-sm btn-danger rounded-pill px-3" @onclick="HandleLogout">Cerrar Sesión</button>
                    </Authorized>
                    <NotAuthorized>
                        <a href="login" class="btn btn-sm btn-light text-dark rounded-pill px-4 me-2">Iniciar Sesión</a>
                        <a href="registro" class="btn btn-sm btn-outline-light rounded-pill px-4">Registrarse</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        carritoService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        carritoService.OnChange -= StateHasChanged;
    }

    private void HandleLogout()
    {
        authService.Logout();
        navManager.NavigateTo("/", true);
    }
}